# Set default behaviour to automatically normalise line endings
* text=auto eol=crlf

# Source files
*.cs        text eol=crlf
*.csx       text eol=crlf
*.axaml     text eol=crlf
*.xml       text eol=crlf
*.xaml      text eol=crlf
*.props     text eol=crlf
*.targets   text eol=crlf
*.csproj    text eol=crlf
*.slnx      text eol=crlf
*.sln       text eol=crlf

# Config / data
*.json      text eol=crlf
*.yml       text eol=crlf
*.yaml      text eol=crlf
*.toml      text eol=crlf
*.ini       text eol=crlf
*.config    text eol=crlf
*.editorconfig text eol=crlf

# Scripts
*.sh        text eol=lf
*.bash      text eol=lf
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Docs
*.md        text eol=crlf
*.txt       text eol=crlf
*.rst       text eol=crlf
LICENSE     text eol=crlf

# Binary files – never modify
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.svg       binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.eot       binary
*.dll       binary
*.exe       binary
*.pdb       binary
*.zip       binary
*.7z        binary
*.tar       binary
*.gz        binary
*.nupkg     binary
*.snupkg    binary
